# ER Open API
# Required: actual Eternal Return API key
API_URL_V1="https://open-api.bser.io/v1"
API_URL_V2="https://open-api.bser.io/v2"
API_KEY="YOUR_ER_API_KEY"

# MongoDB
# Required: internal DB used by collectors/statistics workers
MONGO_INTERNAL_URI="mongodb://user:password@host:27017"
# Required: external/view DB used by report sync and public view sync
MONGO_EXTERNAL_URI="mongodb://user:password@host:27017/dbname"

# Discord webhook
# Optional: leave empty to disable webhook notifications
# Format example: https://discord.com/api/webhooks/REPLACE_ME
DISCORD_WEBHOOK_URL=""

# Collector defaults
# Optional: seed nickname used by collect_data_raw
INIT_NICKNAME="YOUR_SAMPLE_NICKNAME"

# Data sync agent
# Required when er_db_sync_worker is enabled
API_BASE="https://YOUR_SERVER_HOST"
INGEST_API_KEY="YOUR_SYNC_API_KEY"
# Optional: comma-separated collection allowlist
SYNC_ALLOWED_COLLECTIONS="versions,character_statistics"

# Report worker
# Optional: override default season for report compare logic
DEFAULT_VERSION_SEASON=""
REPORT_N_TARGET="50"
REPORT_N_MIN="30"
REPORT_MAX_VERSIONS_BACK="2"
REPORT_TTL_DAYS="21"
REPORT_WINDOW_RULE_VERSION="v1"
REPORT_SEASON_CAP="current_season_only"
REPORT_POLL_INTERVAL_SEC="5"
REPORT_MATCHING_MODE="3"
REPORT_JOB_LEASE_SEC="600"
REPORT_JOB_MAX_RETRY="3"
# Optional: empty means hostname:pid based worker id
REPORT_WORKER_LOCK_ID=""

# Optional local log path override
ER_DATA_LOG_FILE=""
LOG_FILE=""
